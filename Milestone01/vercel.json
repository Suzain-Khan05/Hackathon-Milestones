imp ort { createBrowserRouter } from "react-router-dom";
import { Home } from "../pages/Home";
import { Test } from "../pages/Test";

const router = createBrowserRouter([
  {
    path: "/",
    element: Home( ),
  }
  {
    path: "/test",
    element: Test( ),
  }
]);
export { router };
{
    "routes": [
      {
        "src": "/",
        "dest": "/"
      },
      {
        "src": "/test",
        "dest": "/"
      }
    ]
  }
  